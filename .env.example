# =============================================================================
# Goalkeeper Academy — environment variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`.
# =============================================================================

# ----- App ------------------------------------------------------------------
# Public URL of the deployed site (used for OG tags, sitemap, magic-link redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Supabase -------------------------------------------------------------
# From Supabase Dashboard → Project Settings → API
# - Project URL  → NEXT_PUBLIC_SUPABASE_URL
# - Publishable key (sb_publishable_…) → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Server-side service role key (NEVER expose to the browser).
# Required for: inscription persistence + Stripe webhook (server writes).
SUPABASE_SERVICE_ROLE_KEY=

# ----- Cloudflare Turnstile (anti-bot on public forms) ----------------------
# Free, privacy-friendly captcha. Leave BOTH empty to disable (forms still work).
# Get keys at https://dash.cloudflare.com → Turnstile → Add site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----- Stripe (Phase 7 — placeholder, demo mode for now) --------------------
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ----- Resend (Phase 6/7 — transactional emails, not yet wired) -------------
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL="Goalkeeper Academy <noreply@goalkeeperacademy.ch>"
